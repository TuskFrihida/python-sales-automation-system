# =============================================================================
# Sales Automation System - Environment Variables
# -----------------------------------------------------------------------------
# Copy this file to ".env" and fill in your real values.
# The ".env" file is git-ignored and must NEVER be committed.
# Environment variables defined here take priority over config.ini.
# =============================================================================

# --- SMTP / Email credentials ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
# For Gmail use a 16-character App Password (not your normal password).
SENDER_PASSWORD=your_16_char_app_password
# Comma-separated list of recipients.
RECIPIENT_EMAIL=recipient1@email.com, recipient2@email.com

# --- Paths (optional - sensible defaults are used if omitted) ---
DATA_FOLDER=data
REPORTS_FOLDER=reports
LOGS_FOLDER=logs

# --- Behaviour (optional) ---
REPORT_FREQUENCY=daily
CHART_STYLE=seaborn-v0_8
LOG_LEVEL=INFO
